    "settings.fps.hint" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Lower caps save battery and GPU; higher feels smoother on ProMotion displays." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Límites más bajos ahorran batería y GPU; más altos se sienten más suaves en pantallas ProMotion." } }
      }
    },
    "settings.fps.unlimited" : {
      "localizations" : {
